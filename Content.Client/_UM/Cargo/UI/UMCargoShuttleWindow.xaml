<DefaultWindow xmlns="https://spacestation14.io"
               MinSize="300 150"
               Title="Cargo Shuttle"
               Resizable="False">
    <BoxContainer Orientation="Vertical" Align="Center">
        <Label Name="LocationLabel" Align="Center"  Margin="4"></Label>
        <Label Name="StatusLabel" Align="Center"  Margin="4"></Label>
        <BoxContainer Orientation="Horizontal" Align="Center" Margin="4">
            <Label Name="Countdown"></Label>
        </BoxContainer>
        <Button Name="SendButton" MaxWidth="80" Text="Send"></Button>
    </BoxContainer>
</DefaultWindow>
